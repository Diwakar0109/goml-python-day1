# Ignore version control systems
.git
.gitignore

# Ignore local virtual environments
.venv
venv
env

# Ignore IDE settings
.vscode
.idea

# Ignore python bytecode and cache
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore test caches
